                    bgcolor="#F1F2F5">
                    <p class="s4" style="padding-top: 5pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">SWIFT
                        CODE
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 5pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        ${swift}
                    </p>
                </td>
            </tr>
            <tr style="height:36pt">
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s4"
                       style="padding-left: 7pt;padding-right: 17pt;text-indent: 0pt;line-height: 16pt;text-align: left;">
                        Routing &amp; Transit no.
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 5pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">
                        ${transitno}
                    </p>
                </td>
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s4" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">invoice
                        <span class="s3">编号</span>
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 5pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        ${invoiceno}
                    </p>
                </td>
            </tr>
            <tr style="height:21pt">
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        发票附件
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 3pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">
                        ${attach}
                        <span class="s3">个</span>
                    </p>
                </td>
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        期望付款时间
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        ${paydate}
                    </p>
                </td>
            </tr>
            <tr style="height:21pt">
                <td style="width:482pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    colspan="4">
                    <p class="s5" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        以下是财务付款人员填写
                    </p>
                </td>
            </tr>
            <tr style="height:36pt">
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3"
                       style="padding-top: 2pt;padding-left: 7pt;padding-right: 14pt;text-indent: 0pt;line-height: 108%;text-align: left;">
                        付款日期（财务填写）
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s4" style="padding-top: 3pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">
                        ${paytime}
                    </p>
                </td>
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        超申请判断
                    </p>
                </td>
                <td style="width:148pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s3" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">${reason}</p>
                </td>
            </tr>
            <tr style="height:21pt">
                <td style="width:93pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">项目</p>
                </td>
                <td style="width:389pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    colspan="3">
                    <p class="s4" style="padding-top: 5pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">

                    </p>
                </td>
            </tr>
            <tr style="height:21pt">
                <td style="width:482pt;border-top-style:solid;border-top-width:1pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    colspan="4">
                    <p class="s3" style="padding-top: 3pt;text-indent: 0pt;text-align: center;margin-left: 320px">审批进程</p>
                </td>
            </tr>
        </table>
        <table style="border-collapse:collapse;margin-left:5.875pt" cellspacing="0">
            {@each approvelArr as approvel, i}
            {@if approvel.node === "CEG审批"}
            <tr style="height:35pt">
                <td style="width:115pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s4" style="padding-top: 3pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">CEG
                        <span class="s3">审批</span>
                    </p>
                </td>
                <td style="width:210pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s3" style="padding-top: 3pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">
                        ${approvel.now}
                    </p>
                </td>
                <td style="width:223pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36">
                    <p class="s3" style="padding-top: 2pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        <span class="s3">${ceg}</span>
                    </p>
                </td>
            </tr>
            {@else}
            <tr style="height:21pt">
                <td style="width:112pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-left-style:solid;border-left-width:1pt;border-left-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 4pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">
                        ${approvel.node}
                    </p>
                </td>
                <td style="width:450pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;border-bottom-style:solid;border-bottom-width:0.5pt;border-bottom-color:#2A2E36;border-right-style:solid;border-right-width:1pt;border-right-color:#2A2E36"
                    colspan="3">
                    <p class="s4" style="padding-top: 4pt;padding-left: 6pt;text-indent: 0pt;text-align: left;">
                        ${approvel.now}
                    </p>
                </td>
            </tr>
            {@/if}
            {@/each}
        </table>
        <table style="border-collapse:collapse;margin-left:5.875pt" cellspacing="0">
            <tr style="height:21pt">
                <td style="width:565pt;border-top-style:solid;border-top-width:0.5pt;border-top-color:#2A2E36;" bgcolor="#F1F2F5">
                    <p class="s3" style="padding-top: 4pt;padding-left: 7pt;text-indent: 0pt;text-align: left;">&nbsp;</p>
                </td>
            </tr>
        </table>
    </body>
